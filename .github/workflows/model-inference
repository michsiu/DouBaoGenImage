name: Run Qwen2.5-Sex Model Inference

on:
  push:
    paths:
      - 'task.txt'
    branches:
      - main
      - master
  workflow_dispatch:
    inputs:
      prompt:
        description: '输入提示词'
        required: true
        default: '你好'
      temperature:
        description: '温度参数'
        required: false
        default: '0.3'
      max_tokens:
        description: '最大生成令牌数'
        required: false
        default: '512'

jobs:
  # 解析 task.txt 配置
  parse-config:
    runs-on: ubuntu-latest
    outputs:
      prompt: ${{ steps.parse.outputs.PROMPT }}
      temperature: ${{ steps.parse.outputs.TEMPERATURE }}
      top_p: ${{ steps.parse.outputs.TOP_P }}
      top_k: ${{ steps.parse.outputs.TOP_K }}
      max_tokens: ${{ steps.parse.outputs.MAX_TOKENS }}
      system_message: ${{ steps.parse.outputs.SYSTEM_MESSAGE }}
      save_artifacts: ${{ steps.parse.outputs.SAVE_ARTIFACTS }}
    steps:
      - uses: actions/checkout@v4
      
      - name: Parse task.txt
        id: parse
        run: |
          if [ -f "task.txt" ]; then
            while IFS='=' read -r key value; do
              [[ $key =~ ^#.*$ ]] && continue
              [[ -z $key ]] && continue
              value=$(echo "$value" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^"//;s/"$//')
              echo "${key}=${value}" >> $GITHUB_OUTPUT
            done < task.txt
          fi

  # 运行模型推理
  run-inference:
    needs: parse-config
    runs-on: ubuntu-latest
    timeout-minutes: 30
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Cache Hugging Face models
        uses: actions/cache@v4
        with:
          path: ~/.cache/huggingface
          key: hf-models-qwen2.5-sex-${{ runner.os }}-${{ hashFiles('requirements.txt') }}
          restore-keys: |
            hf-models-qwen2.5-sex-${{ runner.os }}-

      - name: Cache pip packages
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: pip-${{ runner.os }}-${{ hashFiles('requirements.txt') }}
          restore-keys: |
            pip-${{ runner.os }}-

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install torch --index-url https://download.pytorch.org/whl/cpu
          pip install transformers>=4.44.2 accelerate
          pip install huggingface_hub

      - name: Download model
        run: |
          python -c "
          from huggingface_hub import snapshot_download
          import os
          
          model_name = 'ystemsrx/Qwen2.5-Sex'
          
          print(f'Downloading model: {model_name}')
          snapshot_download(
              repo_id=model_name,
              resume_download=True,
              ignore_patterns=['*.md', '*.txt']
          )
          print('Model downloaded successfully!')
          "

      - name: Run inference
        id: inference
        run: |
          python run_inference.py \
            --prompt "${{ needs.parse-config.outputs.prompt || '你好' }}" \
            --temperature ${{ needs.parse-config.outputs.temperature || 3 }} \
            --top-p ${{ needs.parse-config.outputs.top_p || 9 }} \
            --top-k ${{ needs.parse-config.outputs.top_k || 80 }} \
            --max-tokens ${{ needs.parse-config.outputs.max_tokens || 512 }} \
            --system-message "${{ needs.parse-config.outputs.system_message || '' }}" \
            --output result.txt

      - name: Display result
        run: |
          echo "============================================"
          echo "推理结果:"
          echo "============================================"
          cat result.txt
          echo ""
          echo "============================================"

      - name: Upload inference result
        if: needs.parse-config.outputs.save_artifacts == 'true'
        uses: actions/upload-artifact@v4
        with:
          name: inference-result
          path: result.txt
          retention-days: 7
          compression-level: 6

  # 批量处理模式
  batch-inference:
    needs: parse-config
    if: needs.parse-config.outputs.save_artifacts == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 60
    
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup environment
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Cache models
        uses: actions/cache@v4
        with:
          path: ~/.cache/huggingface
          key: hf-models-qwen2.5-sex-${{ runner.os }}

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install torch --index-url https://download.pytorch.org/whl/cpu
          pip install transformers>=4.44.2 accelerate huggingface_hub

      - name: Run batch inference from prompts.txt
        run: |
          if [ -f "prompts.txt" ]; then
            python run_batch_inference.py \
              --input prompts.txt \
              --output batch_results.json \
              --temperature ${{ needs.parse-config.outputs.temperature || 3 }} \
              --top-p ${{ needs.parse-config.outputs.top_p || 9 }} \
              --top-k ${{ needs.parse-config.outputs.top_k || 80 }} \
              --max-tokens ${{ needs.parse-config.outputs.max_tokens || 512 }}
            
            echo "批量推理结果:"
            cat batch_results.json | python -m json.tool
          else
            echo "No prompts.txt found, skipping batch inference"
          fi

      - name: Upload batch results
        uses: actions/upload-artifact@v4
        with:
          name: batch-results
          path: batch_results.json
          retention-days: 7
          compression-level: 6

  # 生成摘要报告
  summary:
    needs: [parse-config, run-inference, batch-inference]
    if: always()
    runs-on: ubuntu-latest
    steps:
      - name: Download inference result
        if: needs.parse-config.outputs.save_artifacts == 'true'
        uses: actions/download-artifact@v4
        with:
          name: inference-result
          
      - name: Download batch results
        if: needs.parse-config.outputs.save_artifacts == 'true'
        uses: actions/download-artifact@v4
        with:
          name: batch-results
          
      - name: Generate summary
        run: |
          echo "# Qwen2.5-Sex 推理报告" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "## 推理参数" >> $GITHUB_STEP_SUMMARY
          echo "- 温度: ${{ needs.parse-config.outputs.temperature || 0.3 }}" >> $GITHUB_STEP_SUMMARY
          echo "- Top-P: ${{ needs.parse-config.outputs.top_p || 0.9 }}" >> $GITHUB_STEP_SUMMARY
          echo "- Top-K: ${{ needs.parse-config.outputs.top_k || 80 }}" >> $GITHUB_STEP_SUMMARY
          echo "- 最大令牌数: ${{ needs.parse-config.outputs.max_tokens || 512 }}" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          
          if [ -f "result.txt" ]; then
            echo "## 推理结果" >> $GITHUB_STEP_SUMMARY
            echo '```' >> $GITHUB_STEP_SUMMARY
            cat result.txt >> $GITHUB_STEP_SUMMARY
            echo '```' >> $GITHUB_STEP_SUMMARY
          fi
          
          if [ -f "batch_results.json" ]; then
            echo "## 批量推理统计" >> $GITHUB_STEP_SUMMARY
            echo "批量推理已完成，详情请下载 artifact" >> $GITHUB_STEP_SUMMARY
          fi
          
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "🕐 完成时间: $(date '+%Y-%m-%d %H:%M:%S')" >> $GITHUB_STEP_SUMMARY